# Logyard configuration

# db_path: ./logyard.db
# retention: 14  # days
# debug: false

# listen:
#   udp: ":514"
#   tcp: ":514"

# web_addr: ":8080"

# URL used in alert emails (defaults to http://<hostname>:<web_port>)
# url: "https://logyard.example.com"

smtp:
  host: smtp.example.com
  port: 587
  user: alerts@example.com
  password: secret
  from: alerts@example.com
  to: admin@example.com

alerts:
  - name: "Many warnings"
    count: 10
    window_minutes: 5
    level: warning
  - name: "Any critical"
    count: 1
    window_minutes: 5
    level: crit
  - name: "Nginx errors"
    count: 5
    window_minutes: 10
    level: err
    tag: nginx
    message: "timeout|connection refused"

ignore:
  - host: noisy-box.lan
  - facility: kern
  - tag: CRON
  - host: proxmox
    level: warning
  - message: "CRON|systemd-.*"
  - host: noisy-box.lan
    discard: true

# Digest mode batches multiple alerts into a single email with
# escalating windows to reduce noise during persistent issues.
# digest:
#   enabled: true
#   initial: "5m"       # first digest window
#   multiplier: 3       # multiply window each escalation (min 1.5)
#   max: "2h"           # maximum window cap
#   cooldown: "10m"     # quiet period before resetting to initial

severity_rewrite:
  # Facility-based: covers all containers using that facility
  # (set via daemon.json or --log-opt syslog-facility=local0)
  - facility: local0
    level: info
    message: "ERROR|FATAL"
    new_severity: err
  - facility: local0
    level: info
    message: "WARN"
    new_severity: warning
  # Tag-based: target specific containers
  # - tag: my-docker-app
  #   level: info
  #   message: "ERROR|FATAL"
  #   new_severity: err
